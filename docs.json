{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AXL Protocol",
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "logo": {
    "light": "/logo/banner.png",
    "dark": "/logo/banner.png"
  },
  "favicon": "/logo/favicon.jpg",
  "colors": {
    "primary": "#fbbf24",
    "light": "#f59e0b",
    "dark": "#fbbf24"
  },
  "font": {
    "headings": { "family": "JetBrains Mono", "weight": 700 },
    "body": { "family": "Inter" }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["overview/introduction", "overview/quickstart", "overview/why-axl", "overview/model-entry-points"]
          },
          {
            "group": "The Language",
            "pages": ["language/packet-format", "language/seven-operations", "language/six-tags", "language/direction-symbols", "language/encoding-layers", "language/tokenizer-profiles", "language/json-lowering", "language/loss-contracts"]
          },
          {
            "group": "Rosetta",
            "pages": ["rosetta/overview", "rosetta/v3-kernel", "rosetta/canonical-decompression", "rosetta/decompression", "rosetta/genesis-tracking", "rosetta/full-text", "rosetta/changelog"]
          },
          {
            "group": "Products",
            "pages": ["products/silo", "products/compress", "products/sophon", "products/bridge", "products/agent-economy"]
          }
        ]
      },
      {
        "tab": "Developer Guide",
        "groups": [
          {
            "group": "Developer Guide",
            "pages": ["guide/quickstart", "guide/python-library", "guide/cli", "guide/examples"]
          }
        ]
      },
      {
        "tab": "Experiments",
        "groups": [
          {
            "group": "Experiments",
            "pages": ["experiments/overview", "experiments/bg001-first-contact", "experiments/bg002-the-thief", "experiments/bg007-medical"]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Reference",
            "pages": ["reference/grammar", "reference/tokenizer-audit", "reference/compression-data", "reference/roadmap"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/axlprotocol",
          "icon": "github"
        },
        {
          "anchor": "v3 Kernel",
          "href": "https://axlprotocol.org/v3",
          "icon": "scroll"
        },
        {
          "anchor": "PyPI",
          "href": "https://pypi.org/project/axl-core/",
          "icon": "box"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      { "label": "Protocol", "href": "https://axlprotocol.org" },
      { "label": "v3 Kernel", "href": "https://axlprotocol.org/v3" }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/axlprotocol"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/axlprotocol",
      "website": "https://axlprotocol.org"
    }
  },
  "feedback": { "thumbsRating": true, "suggestEdit": true },
  "search": { "prompt": "Search AXL docs..." }
}
